# LiveKit WebRTC credentials
# Get these from your LiveKit server admin or cloud dashboard.
# Copy this file to .env and fill in your values.
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Required application API keys.
# Use long random values. Separate multiple keys with commas.
WITNESS_PREP_API_KEYS=replace-with-long-random-value

# Required browser/app origins. Do not use *.
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000