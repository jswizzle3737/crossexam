# Copy this file to .env. Never commit the completed .env file.

# LiveKit WebRTC server
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=replace-with-a-generated-livekit-key
LIVEKIT_API_SECRET=replace-with-a-long-random-livekit-secret

# Required application API keys.
# Use separate, long random values. Separate multiple keys with commas.
WITNESS_PREP_API_KEYS=replace-with-a-separate-long-random-value

# Required browser/application origins. Wildcards are rejected.
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# OpenRouter model inference
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional runtime paths
# WITNESS_PREP_LOG_DIR=./data/sessions
